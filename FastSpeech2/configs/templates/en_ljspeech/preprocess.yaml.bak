dataset: LJSpeech
path:
  corpus_path: /home/md_dz6/AI/coqui_data/en_ljspeech
  lexicon_path: assets/lexicons/en/librispeech-lexicon.txt
  raw_path: /home/md_dz6/AI/coqui_data/en_ljspeech/wavs
  preprocessed_path: /home/md_dz6/AI/FastSpeech2/workspace/preprocessed/en_ljspeech
preprocessing:
  val_size: 512
  text:
    text_cleaners:
    - english_cleaners
    language: en
  audio:
    sampling_rate: 22050
    max_wav_value: 32768.0
  stft:
    filter_length: 1024
    hop_length: 256
    win_length: 1024
  mel:
    n_mel_channels: 80
    mel_fmin: 0
    mel_fmax: 8000
  pitch:
    feature: phoneme_level
    normalization: true
  energy:
    feature: phoneme_level
    normalization: true
